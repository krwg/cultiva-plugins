{
  "id": "time",
  "name": "Time Widget",
  "version": "2.2.2",
  "author": "krwg",
  "description": "A live clock in the header with quick access to world time zones in a polished sheet UI.",
  "icon": "",
  "entry": "index.js",
  "styles": ["cultiva-sheet-base.css", "styles.css"],
  "permissions": ["storage", "ui"],
  "surfaces": ["header"],
  "minAppVersion": "1.1.0",
  "settings": [
    {
      "key": "format",
      "label": "Time Format",
      "type": "select",
      "options": [
        { "value": "HH:MM:SS", "label": "23:59:59" },
        { "value": "HH:MM", "label": "23:59" },
        { "value": "hh:MM:SS A", "label": "11:59:59 PM" }
      ],
      "default": "HH:MM:SS",
      "i18n": {
        "ru": { "label": "Формат времени" }
      }
    },
    {
      "key": "color",
      "label": "Color",
      "type": "select",
      "options": [
        { "value": "default", "label": "Default" },
        { "value": "green", "label": "Green" },
        { "value": "blue", "label": "Blue" },
        { "value": "purple", "label": "Purple" },
        { "value": "orange", "label": "Orange" },
        { "value": "graphite", "label": "Graphite" },
        { "value": "rainbow", "label": "Rainbow" }
      ],
      "default": "default",
      "i18n": {
        "ru": {
          "label": "Цвет",
          "options": {
            "default": "По умолчанию",
            "green": "Зелёный",
            "blue": "Синий",
            "purple": "Фиолетовый",
            "orange": "Оранжевый",
            "graphite": "Графит",
            "rainbow": "Радуга"
          }
        }
      }
    }
  ]
}
