# Normalize text files to LF so GitHub raw SHA-256 matches Windows checkouts.
* text=auto eol=lf
*.js text eol=lf
*.cjs text eol=lf
*.mjs text eol=lf
*.css text eol=lf
*.json text eol=lf
*.md text eol=lf
*.html text eol=lf
*.svg text eol=lf
*.png binary
*.jpg binary
*.jpeg binary
*.webp binary
*.ico binary
