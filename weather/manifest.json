{
  "id": "weather",
  "name": "Weather Widget",
  "version": "2.3.2",
  "author": "krwg",
  "description": "Current conditions in the header and garden, with hybrid city search for any location worldwide.",
  "icon": "",
  "entry": "index.js",
  "styles": [
    "cultiva-sheet-base.css",
    "styles.css"
  ],
  "permissions": [
    "network",
    "storage",
    "ui"
  ],
  "surfaces": ["header", "garden"],
  "minAppVersion": "1.7.0",
  "data": [
    "cities-ru.json"
  ],
  "settings": [
    {
      "key": "city",
      "label": "City",
      "type": "text",
      "default": "Moscow",
      "i18n": {
        "ru": { "label": "Город" }
      }
    },
    {
      "key": "units",
      "label": "Units",
      "type": "select",
      "options": [
        {
          "value": "celsius",
          "label": "Celsius (°C)"
        },
        {
          "value": "fahrenheit",
          "label": "Fahrenheit (°F)"
        }
      ],
      "default": "celsius",
      "i18n": {
        "ru": {
          "label": "Единицы",
          "options": {
            "celsius": "Цельсий (°C)",
            "fahrenheit": "Фаренгейт (°F)"
          }
        }
      }
    },
    {
      "key": "showInGarden",
      "label": "Show in garden",
      "type": "boolean",
      "default": true,
      "i18n": {
        "ru": { "label": "Показывать в саду" }
      }
    }
  ]
}
