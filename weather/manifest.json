{
  "id": "weather",
  "name": "Weather Widget",
  "version": "2.7.0",
  "author": "krwg",
  "description": "Current conditions in the header and garden, with hybrid city search worldwide. Optional Weather Neo (realistic solar-phase skies, sunrise/sunset, animations), theme bypass, hourly and 7-day forecast. Cyrillic city search + Open-Meteo merge.",
  "icon": "",
  "entry": "index.js",
  "styles": [
    "cultiva-sheet-base.css",
    "styles.css"
  ],
  "permissions": [
    "network",
    "storage",
    "ui"
  ],
  "surfaces": ["header", "garden"],
  "minAppVersion": "1.7.0",
  "data": [
    "cities-ru.json"
  ],
  "settings": [
    {
      "key": "city",
      "label": "City",
      "type": "text",
      "default": "Moscow",
      "i18n": {
        "en": { "label": "City" },
        "ru": { "label": "Город" }
      }
    },
    {
      "key": "units",
      "label": "Units",
      "type": "select",
      "options": [
        { "value": "celsius", "label": "Celsius (°C)" },
        { "value": "fahrenheit", "label": "Fahrenheit (°F)" }
      ],
      "default": "celsius",
      "i18n": {
        "en": {
          "label": "Units",
          "options": {
            "celsius": "Celsius (°C)",
            "fahrenheit": "Fahrenheit (°F)"
          }
        },
        "ru": {
          "label": "Единицы",
          "options": {
            "celsius": "Цельсий (°C)",
            "fahrenheit": "Фаренгейт (°F)"
          }
        }
      }
    },
    {
      "key": "showInGarden",
      "label": "Show in garden",
      "type": "boolean",
      "default": true,
      "i18n": {
        "en": { "label": "Show in garden" },
        "ru": { "label": "Показывать в саду" }
      }
    },
    {
      "key": "neoMode",
      "label": "Weather Neo",
      "type": "boolean",
      "default": false,
      "i18n": {
        "en": { "label": "Weather Neo" },
        "ru": { "label": "Погода Нео" }
      }
    },
    {
      "key": "neoBypassThemes",
      "label": "Neo ignores app theme colors",
      "type": "boolean",
      "default": false,
      "i18n": {
        "en": { "label": "Neo ignores app theme colors" },
        "ru": { "label": "Нео игнорирует цвета темы" }
      }
    },
    {
      "key": "showHourly",
      "label": "Hourly forecast",
      "type": "boolean",
      "default": true,
      "i18n": {
        "en": { "label": "Hourly forecast" },
        "ru": { "label": "Почасовой прогноз" }
      }
    },
    {
      "key": "showDaily",
      "label": "7-day forecast",
      "type": "boolean",
      "default": true,
      "i18n": {
        "en": { "label": "7-day forecast" },
        "ru": { "label": "Прогноз на неделю" }
      }
    }
  ]
}
