{
  "id": "weather",
  "name": "Weather Widget",
  "version": "2.3.2",
  "author": "krwg",
  "description": "Weather in header and garden, city search, sheet UI in the main window. Cultiva 0.4.0+.",
  "icon": "",
  "entry": "index.js",
  "styles": [
    "cultiva-sheet-base.css",
    "styles.css"
  ],
  "permissions": [
    "network",
    "storage",
    "ui"
  ],
  "surfaces": ["header", "garden"],
  "minAppVersion": "1.7.0",
  "data": [
    "cities-ru.json"
  ],
  "settings": [
    {
      "key": "city",
      "label": "City",
      "type": "text",
      "default": "Moscow"
    },
    {
      "key": "units",
      "label": "Units",
      "type": "select",
      "options": [
        {
          "value": "celsius",
          "label": "Celsius (°C)"
        },
        {
          "value": "fahrenheit",
          "label": "Fahrenheit (°F)"
        }
      ],
      "default": "celsius"
    },
    {
      "key": "showInGarden",
      "label": "Show in garden",
      "type": "boolean",
      "default": true
    }
  ]
}