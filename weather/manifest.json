{
  "id": "weather",
  "name": "Weather Widget",
  "version": "2.3.0",
  "author": "krwg",
  "description": "Weather in header and garden, city search, sheet UI in the main window. Cultiva 0.4.0+.",
  "icon": "",
  "entry": "index.js",
  "styles": [
    "cultiva-sheet-base.css",
    "styles.css"
  ],
  "permissions": [
    "network",
    "storage",
    "ui"
  ],
  "minAppVersion": "1.7.0",
  "data": [
    "cities-ru.json"
  ],
  "settings": [
    {
      "key": "city",
      "label": "Город",
      "type": "text",
      "default": "Moscow"
    },
    {
      "key": "units",
      "label": "Единицы",
      "type": "select",
      "options": [
        {
          "value": "celsius",
          "label": "Цельсий (°C)"
        },
        {
          "value": "fahrenheit",
          "label": "Фаренгейт (°F)"
        }
      ],
      "default": "celsius"
    },
    {
      "key": "showInGarden",
      "label": "Показывать в саду",
      "type": "boolean",
      "default": true
    }
  ]
}