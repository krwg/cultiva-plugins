{
  "id": "radio",
  "name": "Radio Widget",
  "version": "2.2.0",
  "author": "krwg",
  "description": "SomaFM streams, sleep timer, and glass sheet UI. Cultiva 0.4.0+.",
  "icon": "",
  "entry": "index.js",
  "styles": ["cultiva-sheet-base.css", "styles.css"],
  "permissions": ["network", "storage", "ui"],
  "surfaces": ["header"],
  "minAppVersion": "1.7.0",
  "settings": [
    {
      "key": "station",
      "label": "Default station",
      "type": "select",
      "options": [
        { "value": "groovesalad", "label": "Groove Salad" },
        { "value": "fluid", "label": "Fluid" },
        { "value": "beatblender", "label": "Beat Blender" },
        { "value": "dronezone", "label": "Drone Zone" },
        { "value": "lush", "label": "Lush" },
        { "value": "spacestation", "label": "Space Station" },
        { "value": "secretagent", "label": "Secret Agent" },
        { "value": "radioparadise", "label": "Radio Paradise" },
        { "value": "chillhop", "label": "Chillhop Radio" },
        { "value": "defcon", "label": "DEF CON Radio" }
      ],
      "default": "groovesalad"
    },
    {
      "key": "volume",
      "label": "Volume",
      "type": "select",
      "options": [
        { "value": "0.25", "label": "25%" },
        { "value": "0.35", "label": "35%" },
        { "value": "0.45", "label": "45%" },
        { "value": "0.55", "label": "55%" },
        { "value": "0.65", "label": "65%" },
        { "value": "0.75", "label": "75%" }
      ],
      "default": "0.45"
    },
    {
      "key": "sleepMinutes",
      "label": "Sleep timer",
      "type": "select",
      "options": [
        { "value": "0", "label": "Off" },
        { "value": "15", "label": "15 min" },
        { "value": "30", "label": "30 min" },
        { "value": "60", "label": "60 min" }
      ],
      "default": "0"
    }
  ]
}
